# ---------------------------------------------------------------------------
# .env.example — Variables para docker compose (root compose.yml)
# ---------------------------------------------------------------------------
# Copia este archivo a .env y completa los valores reales.
# .env está en .gitignore y nunca debe commitearse.
#
# Modo standalone por servicio: cada servicio tiene su propio mecanismo
#   api/     → ./mvnw spring-boot:run -Dspring.profiles.active=local
#              (levanta api/compose.yml automáticamente para la DB)
#   web/     → npm run dev (lee web/.env.local)
# ---------------------------------------------------------------------------

# ---------------------------------------------------------------------------
# Firebase Admin SDK — credenciales del servidor (SECRETO, nunca al browser)
# ---------------------------------------------------------------------------
# Ruta absoluta al archivo JSON de la service account de Firebase Admin.
# Se monta en el contenedor del API como /run/secrets/firebase-admin-key.json
FIREBASE_ADMIN_KEY_PATH=/home/you/.config/gradeops/firebase-service-account.json

# ---------------------------------------------------------------------------
# API — secreto interno para endpoints protegidos entre servicios
# ---------------------------------------------------------------------------
INTERNAL_API_SECRET=dev-secret-change-me

# ---------------------------------------------------------------------------
# Firebase web configuration — baked in durante el build de Next.js
# ---------------------------------------------------------------------------
# Valores disponibles en: Firebase Console → Project Settings → Your apps
NEXT_PUBLIC_FIREBASE_API_KEY=your-firebase-api-key
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=your-project-id.firebaseapp.com
NEXT_PUBLIC_FIREBASE_PROJECT_ID=your-project-id
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=your-project-id.firebasestorage.app
NEXT_PUBLIC_FIREBASE_APP_ID=1:000000000000:web:0000000000000000000000
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=000000000000
NEXT_PUBLIC_FIREBASE_MEASUREMENT_ID=G-XXXXXXXXXX
