---
import { useTranslations } from '../utils/i18n';
import type { Lang } from '../utils/i18n';

interface Props {
  lang: Lang;
}

const { lang } = Astro.props;
const t = useTranslations(lang);
const year = new Date().getFullYear();
---

<footer class="border-t border-white/10 mt-24 py-12">
  <div class="max-w-6xl mx-auto px-4 sm:px-6">
    <div class="flex flex-col md:flex-row items-center justify-between gap-4">
      <!-- Logo + tagline -->
      <div class="text-center md:text-left">
        <div class="font-bold text-lg">
          <span class="text-[var(--teal)]">Grade</span><span class="text-[var(--coral)]">Ops</span><span class="text-[var(--txt-muted)]"> AI</span>
        </div>
        <p class="text-sm text-[var(--txt-muted)] mt-1">{t('footer.tagline')}</p>
      </div>

      <!-- Built with -->
      <div class="text-center">
        <p class="text-xs text-[var(--txt-muted)]">{t('footer.built')}</p>
        <p class="text-xs text-[var(--txt-muted)] mt-1">© {year} GradeOps AI</p>
      </div>

      <!-- Social / links -->
      <div class="flex items-center gap-3">
        <a
          href="https://devpost.com/software/gradeops-ai"
          target="_blank"
          rel="noopener noreferrer"
          aria-label="Devpost"
          class="text-[var(--txt-muted)] hover:text-[var(--teal)] transition-colors"
        >
          <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="currentColor">
            <path d="M6.002 1.61 0 12.004 6.002 22.39h11.996L24 12.004 17.998 1.61zm1.593 4.084h3.947c3.605 0 6.276 1.695 6.276 6.31 0 4.436-3.21 6.302-6.456 6.302H7.595zm2.517 2.449v7.714h1.241c2.476 0 3.898-1.241 3.898-3.857 0-2.448-1.422-3.857-3.898-3.857z"/>
          </svg>
        </a>
        <a
          href="https://github.com/cmartinezs/grade-ops-ai"
          target="_blank"
          rel="noopener noreferrer"
          aria-label="GitHub"
          class="text-[var(--txt-muted)] hover:text-[var(--teal)] transition-colors"
        >
          <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="currentColor">
            <path d="M12 .297c-6.63 0-12 5.373-12 12 0 5.303 3.438 9.8 8.205 11.385.6.113.82-.258.82-.577 0-.285-.01-1.04-.015-2.04-3.338.724-4.042-1.61-4.042-1.61-.546-1.387-1.333-1.756-1.333-1.756-1.089-.745.083-.729.083-.729 1.205.084 1.839 1.237 1.839 1.237 1.07 1.834 2.807 1.304 3.492.997.107-.775.418-1.305.762-1.604-2.665-.305-5.467-1.334-5.467-5.931 0-1.311.469-2.381 1.236-3.221-.124-.303-.535-1.524.117-3.176 0 0 1.008-.322 3.301 1.23.957-.266 1.983-.399 3.003-.404 1.02.005 2.047.138 3.006.404 2.291-1.552 3.297-1.23 3.297-1.23.653 1.653.242 2.874.118 3.176.77.84 1.235 1.911 1.235 3.221 0 4.609-2.807 5.624-5.479 5.921.43.372.823 1.102.823 2.222 0 1.606-.015 2.896-.015 3.286 0 .315.216.694.825.576 4.765-1.589 8.199-6.086 8.199-11.386 0-6.627-5.373-12-12-12z"/>
          </svg>
        </a>
      </div>
    </div>
  </div>
</footer>
