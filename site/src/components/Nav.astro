---
import ThemeToggle from './ThemeToggle.astro';
import LangDropdown from './LangDropdown.astro';
import { useTranslations } from '../utils/i18n';
import type { Lang } from '../utils/i18n';
import type { UIKey } from '../i18n/es';
import { ClipboardList, Code2, Cpu, Trophy, Mail } from 'lucide-astro';

interface Props {
  lang: Lang;
  path: string;
}

const { lang, path } = Astro.props;
const t = useTranslations(lang);
const base = import.meta.env.BASE_URL;
const ls = lang === 'en' ? '/en' : '';

const navLinks = [
  { key: 'nav.requirements', href: `${base}${ls}/requirements`,     Icon: ClipboardList },
  { key: 'nav.development',  href: `${base}${ls}/development`,      Icon: Code2 },
  { key: 'nav.technicals',   href: `${base}${ls}/technicals`,       Icon: Cpu },
  { key: 'nav.xprize',       href: `${base}${ls}/xprize-hackathon`, Icon: Trophy },
  { key: 'nav.contact',      href: `${base}${ls}/contact`,          Icon: Mail },
] as const;
---

<header id="site-nav" class="fixed top-0 left-0 right-0 z-40 transition-all duration-300">
  <nav class="max-w-6xl mx-auto px-4 sm:px-6 flex items-center justify-between h-16">
    <!-- Logo -->
    <a href={base} class="flex items-center gap-2 font-bold text-lg tracking-tight">
      <!-- Graduation cap logomark -->
      <span class="flex items-center justify-center w-8 h-8 rounded-lg bg-[var(--teal)]/10 text-[var(--teal)]">
        <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
          <path d="M22 10v6M2 10l10-5 10 5-10 5z"/>
          <path d="M6 12v5c0 2 2 3 6 3s6-1 6-3v-5"/>
        </svg>
      </span>
      <span class="text-[var(--teal)]">Grade</span><span class="text-[var(--coral)]">Ops</span><span class="text-[var(--txt-muted)] font-normal text-base"> AI</span>
    </a>

    <!-- Desktop links -->
    <ul class="hidden md:flex items-center gap-0.5">
      {navLinks.map(({ key, href, Icon }) => (
        <li>
          <a
            href={href}
            class="flex items-center gap-1.5 px-3 py-1.5 text-sm text-[var(--txt-muted)] hover:text-[var(--txt)] rounded-lg hover:bg-white/10 transition-colors"
          >
            <Icon size={14} />
            {t(key as UIKey)}
          </a>
        </li>
      ))}
    </ul>

    <!-- Controls -->
    <div class="flex items-center gap-1">
      <ThemeToggle />
      <LangDropdown lang={lang} path={path} />

      <!-- Mobile hamburger -->
      <button
        id="nav-hamburger"
        aria-label="Open menu"
        class="md:hidden p-2 rounded-lg hover:bg-white/10 transition-colors text-[var(--txt-muted)]"
      >
        <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
          <line x1="3" y1="6" x2="21" y2="6"/>
          <line x1="3" y1="12" x2="21" y2="12"/>
          <line x1="3" y1="18" x2="21" y2="18"/>
        </svg>
      </button>
    </div>
  </nav>

  <!-- Mobile menu -->
  <div
    id="nav-mobile"
    class="hidden md:hidden border-t border-white/10 bg-[#07111F]/95 backdrop-blur-md px-4 py-3"
  >
    {navLinks.map(({ key, href, Icon }) => (
      <a
        href={href}
        class="flex items-center gap-2 py-2.5 text-sm text-[var(--txt-muted)] hover:text-[var(--txt)] transition-colors"
      >
        <Icon size={16} />
        {t(key as UIKey)}
      </a>
    ))}
  </div>
</header>

<div class="h-16"></div>

<script is:inline>
  (function () {
    var nav = document.getElementById('site-nav');
    var hamburger = document.getElementById('nav-hamburger');
    var mobile = document.getElementById('nav-mobile');

    window.addEventListener('scroll', function () {
      if (window.scrollY > 10) {
        nav.classList.add('bg-[#07111F]/90', 'backdrop-blur-md', 'border-b', 'border-white/10');
      } else {
        nav.classList.remove('bg-[#07111F]/90', 'backdrop-blur-md', 'border-b', 'border-white/10');
      }
    });

    hamburger.addEventListener('click', function () {
      mobile.classList.toggle('hidden');
    });
  })();
</script>
