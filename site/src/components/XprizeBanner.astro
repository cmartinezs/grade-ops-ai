---
import { useTranslations } from '../utils/i18n';
import type { Lang } from '../utils/i18n';

interface Props {
  lang: Lang;
}

const { lang } = Astro.props;
const t = useTranslations(lang);
const base = import.meta.env.BASE_URL;
const ls = lang === 'en' ? '/en' : '';
---

<div class="relative overflow-hidden rounded-2xl border border-[var(--coral)]/20 bg-gradient-to-r from-[var(--coral)]/5 to-[var(--indigo)]/5 px-6 py-8 my-16 mx-4 sm:mx-0">
  <!-- Decorative glow -->
  <div class="absolute -top-12 -right-12 w-48 h-48 bg-[var(--coral)]/10 rounded-full blur-3xl pointer-events-none"></div>
  <div class="absolute -bottom-12 -left-12 w-48 h-48 bg-[var(--indigo)]/10 rounded-full blur-3xl pointer-events-none"></div>

  <div class="relative flex flex-col sm:flex-row items-center justify-between gap-4">
    <div class="flex items-center gap-4">
      <!-- Trophy icon -->
      <div class="w-12 h-12 rounded-xl bg-[var(--coral)]/10 border border-[var(--coral)]/20 flex items-center justify-center text-[var(--coral)] shrink-0">
        <svg xmlns="http://www.w3.org/2000/svg" width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
          <polyline points="8 21 12 17 16 21"/><line x1="12" y1="17" x2="12" y2="11"/>
          <path d="M7 4H4a2 2 0 0 0-2 2v1c0 2.76 2.24 5 5 5 .54 0 1.07-.08 1.57-.23"/>
          <path d="M17 4h3a2 2 0 0 1 2 2v1c0 2.76-2.24 5-5 5-.54 0-1.07-.08-1.57-.23"/>
          <path d="M7 4h10v7a5 5 0 0 1-10 0V4z"/>
        </svg>
      </div>
      <div>
        <div class="font-semibold text-[var(--txt)]">{t('xprize.text')}</div>
        <div class="text-sm text-[var(--txt-muted)] mt-0.5">{t('xprize.deadline')}</div>
      </div>
    </div>
    <a
      href={`${base}${ls}/xprize-hackathon`}
      class="shrink-0 inline-flex items-center gap-2 px-4 py-2 rounded-lg bg-[var(--coral)] hover:bg-[var(--coral)]/80 text-white text-sm font-semibold transition-colors"
    >
      {t('xprize.cta')}
      <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
        <polyline points="9 18 15 12 9 6"/>
      </svg>
    </a>
  </div>
</div>
