---
import '../styles/global.css';
import Nav from '../components/Nav.astro';
import Footer from '../components/Footer.astro';
import type { Lang } from '../utils/i18n';

interface Props {
  title: string;
  description: string;
  lang: Lang;
  path: string;
}

const { title, description, lang, path } = Astro.props;
const base = import.meta.env.BASE_URL;
const langSeg = lang === 'en' ? '/en' : '';
const canonicalUrl = `https://cmartinezs.github.io${base}${langSeg}${path === '/' ? '' : path}`;
---

<!doctype html>
<html lang={lang}>
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={canonicalUrl} />

    <!-- OG / Social -->
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonicalUrl} />
    <meta property="og:type" content="website" />
    <meta property="og:image" content={`https://cmartinezs.github.io${base}/og-image.png`} />
    <meta name="twitter:card" content="summary_large_image" />

    <link rel="icon" type="image/svg+xml" href={`${base}/favicon.svg`} />

    <!-- Inline theme init — must run before paint to avoid FOUC -->
    <script is:inline>
      (function () {
        var stored = localStorage.getItem('theme');
        var prefersDark = window.matchMedia('(prefers-color-scheme: dark)').matches;
        var theme = stored || (prefersDark ? 'dark' : 'light');
        document.documentElement.classList.add(theme);
      })();
    </script>
  </head>
  <body>
    <Nav lang={lang} path={path} />
    <main>
      <slot />
    </main>
    <Footer lang={lang} />
  </body>
</html>
