---
import Base from '../../layouts/Base.astro';
import StatStrip from '../../components/StatStrip.astro';
import Pipeline from '../../components/Pipeline.astro';
import Features from '../../components/Features.astro';
import RoadmapPreview from '../../components/RoadmapPreview.astro';
import XprizeBanner from '../../components/XprizeBanner.astro';
import { useTranslations } from '../../utils/i18n';

const lang = 'en';
const t = useTranslations(lang);
const base = import.meta.env.BASE_URL;
---

<Base
  title="GradeOps AI — Assessment operations for programming educators"
  description="GradeOps AI operates the full assessment cycle with AI agents. Teachers approve; agents execute."
  lang={lang}
  path="/"
>
  <!-- Hero -->
  <section class="relative min-h-[90vh] flex flex-col items-center justify-center text-center overflow-hidden px-4 py-20">
    <div class="absolute inset-0 overflow-hidden pointer-events-none">
      <div class="absolute top-1/4 left-1/2 -translate-x-1/2 w-[600px] h-[300px] bg-[var(--teal)]/10 rounded-full blur-3xl"></div>
      <div class="absolute bottom-1/4 left-1/3 w-64 h-64 bg-[var(--indigo)]/5 rounded-full blur-3xl"></div>
    </div>

    <div class="hero-hidden relative mb-6 inline-flex items-center gap-2 px-4 py-1.5 rounded-full border border-[var(--teal)]/30 bg-[var(--teal)]/5 text-xs font-medium text-[var(--teal)]">
      <span class="w-1.5 h-1.5 rounded-full bg-[var(--coral)] animate-pulse"></span>
      {t('hero.badge')}
    </div>

    <h1 class="hero-hidden relative max-w-4xl">
      <span class="block text-5xl sm:text-7xl font-extrabold tracking-tight text-[var(--txt)]">{t('hero.h1')}</span>
      <span class="block text-5xl sm:text-7xl font-extrabold tracking-tight text-[var(--teal)] mt-1">{t('hero.h2')}</span>
      <span class="block text-5xl sm:text-7xl font-extrabold tracking-tight text-[var(--coral)] mt-1">{t('hero.h3')}</span>
    </h1>

    <p class="hero-hidden relative mt-8 max-w-2xl text-lg text-[var(--txt-muted)] leading-relaxed">
      {t('hero.sub')}
    </p>

    <div class="hero-hidden relative mt-10 flex flex-wrap items-center justify-center gap-4">
      <a
        href={`${base}/en/requirements`}
        class="px-6 py-3 rounded-xl bg-[var(--teal)] hover:bg-[var(--teal)]/80 text-white font-semibold transition-all duration-200 shadow-lg shadow-[var(--teal)]/20"
      >
        {t('hero.cta.primary')}
      </a>
      <a
        href={`${base}/en/development`}
        class="px-6 py-3 rounded-xl border border-white/20 hover:border-[var(--teal)]/40 text-[var(--txt-muted)] hover:text-[var(--txt)] font-medium transition-all duration-200"
      >
        {t('hero.cta.secondary')}
      </a>
    </div>

    <div class="hero-hidden absolute bottom-8 left-1/2 -translate-x-1/2 text-[var(--txt-muted)] animate-bounce">
      <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
        <polyline points="6 9 12 15 18 9"/>
      </svg>
    </div>
  </section>

  <StatStrip lang={lang} />
  <Pipeline lang={lang} />
  <Features lang={lang} />
  <div class="max-w-6xl mx-auto px-4 sm:px-6">
    <XprizeBanner lang={lang} />
  </div>
  <RoadmapPreview lang={lang} />
</Base>

<style>
  .hero-hidden {
    opacity: 0;
    transform: translateY(24px);
  }
</style>

<script is:inline>
  (function () {
    var els = document.querySelectorAll('.hero-hidden');
    els.forEach(function (el, i) {
      setTimeout(function () {
        el.style.transition = 'opacity 0.6s ease, transform 0.6s ease';
        el.style.opacity = '1';
        el.style.transform = 'translateY(0)';
      }, 100 + i * 120);
    });
  })();
</script>
