---
import Base from '../layouts/Base.astro';
import SectionHero from '../components/SectionHero.astro';
import { useTranslations } from '../utils/i18n';

const lang = 'es';
const t = useTranslations(lang);

const stack = [
  {
    category: 'Frontend',
    color: 'teal',
    icon: 'M3 12l2-2m0 0l7-7 7 7M5 10v10a1 1 0 001 1h3m10-11l2 2m-2-2v10a1 1 0 01-1 1h-3m-6 0a1 1 0 001-1v-4a1 1 0 011-1h2a1 1 0 011 1v4a1 1 0 001 1m-6 0h6',
    items: [
      { name: 'Next.js 15', desc: 'App Router, Server Components, proxy rewrites hacia la API' },
      { name: 'TypeScript', desc: 'Tipado estático end-to-end; los DTOs fluyen de API a Web' },
      { name: 'Tailwind CSS', desc: 'Utility-first styling, diseño responsivo' },
    ],
  },
  {
    category: 'API (dominio)',
    color: 'indigo',
    icon: 'M5 12h14M12 5l7 7-7 7',
    items: [
      { name: 'Spring Boot 4 + Java 21', desc: 'Modular monolith con módulos independientes por dominio' },
      { name: 'PostgreSQL + Flyway', desc: 'Base de datos principal; migraciones versionadas' },
      { name: 'Spring Data JPA', desc: 'Persistencia de entidades de dominio' },
      { name: 'OIDC service-to-service', desc: 'Autenticación interna entre API y Agents (Cloud Run)' },
    ],
  },
  {
    category: 'Agentes de IA',
    color: 'coral',
    icon: 'M9.663 17h4.673M12 3v1m6.364 1.636l-.707.707M21 12h-1M4 12H3m3.343-5.657l-.707-.707m2.828 9.9a5 5 0 117.072 0l-.548.547A3.374 3.374 0 0014 18.469V19a2 2 0 11-4 0v-.531c0-.895-.356-1.754-.988-2.386l-.548-.547z',
    items: [
      { name: 'Spring Boot 4 + Spring AI', desc: 'Runtime de agentes, separado del API de dominio' },
      { name: 'Vertex AI Gemini', desc: 'Modelo de lenguaje para todos los agentes' },
      { name: 'StringTemplate (.st)', desc: 'Prompts versionados como archivos; nunca inline en Java' },
      { name: 'AgentExecutionLog', desc: 'Cada llamada genera un registro estructurado de evidencia' },
    ],
  },
  {
    category: 'Infraestructura',
    color: 'teal',
    icon: 'M3 15a4 4 0 004 4h9a5 5 0 10-.1-9.999 5.002 5.002 0 10-9.78 2.096A4.001 4.001 0 003 15z',
    items: [
      { name: 'Google Cloud Run', desc: 'Hosting de Web, API y Agents (contenedores sin estado)' },
      { name: 'Cloud SQL (PostgreSQL)', desc: 'Base de datos gestionada en GCP' },
      { name: 'Cloud Storage', desc: 'Almacenamiento de archivos de evaluación y entregables' },
      { name: 'Secret Manager', desc: 'Gestión de credenciales y API keys' },
      { name: 'Terraform', desc: 'Infraestructura como código; entorno demo para hackathon' },
      { name: 'GitHub Actions', desc: 'CI/CD para build, test y deploy automático' },
    ],
  },
];

const principles = [
  {
    title: 'Tipos fluyen de API a Web',
    desc: 'El frontend refleja los contratos de DTOs de la API. No hay definiciones de tipos independientes en el frontend.',
  },
  {
    title: 'Agentes no poseen entidades',
    desc: 'Los agentes reciben un Command, retornan un Result, y no persisten nada directamente. La persistencia es responsabilidad de la API.',
  },
  {
    title: 'Prompts versionados como archivos',
    desc: 'Todos los prompts están en src/main/resources/prompts/ como archivos .st (StringTemplate). Nunca inline en código Java.',
  },
  {
    title: 'Aprobación del docente es explícita',
    desc: 'Todo output de IA que afecte calificaciones, feedback o contenido estudiantil requiere un ApprovalEvent antes de ser procesado.',
  },
  {
    title: 'Evidencia es core, no efecto secundario',
    desc: 'AgentExecutionLog, ApprovalEvent, UsageEvent, RevenueEvent y CostEvent son entidades de primera clase.',
  },
  {
    title: 'Sin login estudiantil en MVP',
    desc: 'Los estudiantes acceden mediante token firmado (AssessmentInvitation). LearnerRef es una referencia mínima, no una cuenta.',
  },
];

const entities = [
  { name: 'Assessment', purpose: 'Ciclo de evaluación con modo (Open/Closed), objetivo de aprendizaje y estado de workflow' },
  { name: 'Rubric', purpose: 'Criterios y pesos aprobados por el docente; inmutable una vez congelada' },
  { name: 'StudentSubmission', purpose: 'Trabajo entregado por el estudiante; input para el agente de calificación' },
  { name: 'GradeSuggestion', purpose: 'Sugerencia de calificación del agente; requiere ApprovalEvent para finalizarse' },
  { name: 'FeedbackDraft', purpose: 'Feedback generado por AI; requiere aprobación antes de entregarse al estudiante' },
  { name: 'AgentExecutionLog', purpose: 'Registro de cada ejecución: modelo, tokens, costo, estado de aprobación' },
  { name: 'ApprovalEvent', purpose: 'Aprobación/rechazo explícito del docente sobre cualquier output de AI' },
  { name: 'AssessmentInvitation', purpose: 'Link firmado para acceso del estudiante sin cuenta' },
  { name: 'Question', purpose: 'Pregunta del banco (Closed); versionada y curada por el docente' },
];

const apiGroups = [
  { group: 'Evaluación core', resources: '/assessments, /rubrics, /submissions' },
  { group: 'Outputs de AI', resources: '/grading-suggestions, /feedback-drafts, /learning-gaps, /recovery-activities' },
  { group: 'Reportes', resources: '/teacher-reports, /agent-runs, /evidence' },
  { group: 'Evaluación cerrada', resources: '/questions (banco), /assessment-attempts' },
  { group: 'Plataforma', resources: '/auth/me, /organizations, /usage' },
];

const securityCards = [
  {
    title: 'Aislamiento por tenant',
    desc: 'Cada docente solo accede a registros de su organización. Violación → respuesta 404, nunca 403 (evita revelar existencia del recurso).',
  },
  {
    title: 'Llamadas AI solo server-side',
    desc: 'La Gemini API key nunca llega al frontend. Solo el servicio de Agents llama al modelo; el Web no tiene acceso.',
  },
  {
    title: 'Aprobación como control de seguridad',
    desc: 'Los outputs de AI de alto impacto (rúbrica, calificación, feedback) permanecen en estado pending hasta que un ApprovalEvent explícito los finaliza.',
  },
];
---

<Base
  title="Técnico — GradeOps AI"
  description="Stack tecnológico, decisiones de diseño y arquitectura del sistema GradeOps AI."
  lang={lang}
  path="/technicals"
>
  <div class="fixed inset-0 pointer-events-none select-none" aria-hidden="true"
       style="background-image: repeating-linear-gradient(0deg, rgba(255,255,255,0.06) 0px, rgba(255,255,255,0.06) 1px, transparent 1px, transparent 48px); z-index: 0;">
  </div>

  <SectionHero
    title={t('tech.title')}
    subtitle={t('tech.sub')}
    accentColor="indigo"
  />

  <!-- Architecture diagram (text-based) -->
  <div class="max-w-4xl mx-auto px-4 sm:px-6 mb-16">
    <div class="rounded-2xl border border-white/10 bg-white/[0.02] p-6 sm:p-8 font-mono text-sm overflow-x-auto">
      <div class="text-[var(--txt-muted)] mb-4 text-xs uppercase tracking-widest">Flujo de arquitectura</div>
      <pre class="reveal-lines text-[var(--txt)] leading-7 whitespace-pre"><span class="block">Browser → Web (Next.js)  →  API (Spring Boot)  →  Agents (Spring Boot / Spring AI)</span><span class="block">                                      ↓                          ↓</span><span class="block">                               Cloud SQL (PG)           Vertex AI Gemini</span><span class="block">                               Cloud Storage</span></pre>
      <div class="mt-4 pt-4 border-t border-white/10 text-[var(--txt-muted)] text-xs leading-6 space-y-1">
        <div><span class="text-[var(--teal)]">Web</span> — Teacher workspace, acceso estudiantil por token, dashboards</div>
        <div><span class="text-[var(--indigo)]">API</span> — Lógica de dominio, máquina de estados, persistencia, facturación</div>
        <div><span class="text-[var(--coral)]">Agents</span> — REST interno; OIDC service-to-service; no expuesto al público</div>
      </div>
    </div>
  </div>

  <!-- Stack -->
  <div class="max-w-4xl mx-auto px-4 sm:px-6 mb-16 space-y-8">
    <h2 class="text-2xl font-bold text-[var(--txt)]">Stack tecnológico</h2>
    <div class="grid sm:grid-cols-2 gap-6">
      {stack.map((layer, i) => {
        const colorMap = {
          teal:   { title: 'text-[var(--teal)]',   border: 'border-[var(--teal)]/20',   icon: 'text-[var(--teal)]',   dot: 'bg-[var(--teal)]' },
          indigo: { title: 'text-[var(--indigo)]', border: 'border-[var(--indigo)]/20', icon: 'text-[var(--indigo)]', dot: 'bg-[var(--indigo)]' },
          coral:  { title: 'text-[var(--coral)]',  border: 'border-[var(--coral)]/20',  icon: 'text-[var(--coral)]',  dot: 'bg-[var(--coral)]' },
        };
        const c = colorMap[layer.color as keyof typeof colorMap];
        return (
          <div class={`reveal rounded-2xl border ${c.border} p-5`} style={`transition-delay: ${i * 100}ms`}>
            <div class={`flex items-center gap-2 mb-4 ${c.title} font-semibold`}>
              <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                <path d={layer.icon}/>
              </svg>
              {layer.category}
            </div>
            <ul class="space-y-3">
              {layer.items.map((item) => (
                <li>
                  <div class="flex items-start gap-2">
                    <span class={`mt-2 shrink-0 w-1.5 h-1.5 rounded-full ${c.dot}`}></span>
                    <div>
                      <span class="text-sm font-medium text-[var(--txt)]">{item.name}</span>
                      <p class="text-xs text-[var(--txt-muted)] mt-0.5">{item.desc}</p>
                    </div>
                  </div>
                </li>
              ))}
            </ul>
          </div>
        );
      })}
    </div>
  </div>

  <!-- Core Domain Entities -->
  <div class="reveal max-w-4xl mx-auto px-4 sm:px-6 mb-16">
    <h2 class="text-2xl font-bold text-[var(--txt)] mb-6">Entidades del Dominio</h2>
    <div class="rounded-2xl border border-white/10 bg-white/[0.02] overflow-hidden">
      <table class="w-full text-sm">
        <thead>
          <tr class="border-b border-white/10">
            <th class="text-left px-5 py-3 text-xs uppercase tracking-widest text-[var(--txt-muted)] font-medium w-48">Entidad</th>
            <th class="text-left px-5 py-3 text-xs uppercase tracking-widest text-[var(--txt-muted)] font-medium">Propósito</th>
          </tr>
        </thead>
        <tbody>
          {entities.map((e, i) => (
            <tr class={`border-b border-white/[0.05] ${i % 2 === 0 ? '' : 'bg-white/[0.01]'}`}>
              <td class="px-5 py-3 font-mono text-sm text-[var(--teal)] whitespace-nowrap">{e.name}</td>
              <td class="px-5 py-3 text-xs text-[var(--txt-muted)] leading-relaxed">{e.purpose}</td>
            </tr>
          ))}
        </tbody>
      </table>
    </div>
  </div>

  <!-- API Resources -->
  <div class="reveal max-w-4xl mx-auto px-4 sm:px-6 mb-16">
    <h2 class="text-2xl font-bold text-[var(--txt)] mb-6">Recursos del API</h2>
    <div class="rounded-2xl border border-white/10 bg-white/[0.02] overflow-hidden">
      <table class="w-full text-sm">
        <thead>
          <tr class="border-b border-white/10">
            <th class="text-left px-5 py-3 text-xs uppercase tracking-widest text-[var(--txt-muted)] font-medium w-48">Grupo</th>
            <th class="text-left px-5 py-3 text-xs uppercase tracking-widest text-[var(--txt-muted)] font-medium">Recursos</th>
          </tr>
        </thead>
        <tbody>
          {apiGroups.map((g, i) => (
            <tr class={`border-b border-white/[0.05] ${i % 2 === 0 ? '' : 'bg-white/[0.01]'}`}>
              <td class="px-5 py-3 text-xs text-[var(--txt)] font-medium whitespace-nowrap">{g.group}</td>
              <td class="px-5 py-3 font-mono text-xs text-[var(--indigo)]">{g.resources}</td>
            </tr>
          ))}
        </tbody>
      </table>
    </div>
  </div>

  <!-- Security Principles -->
  <div class="max-w-4xl mx-auto px-4 sm:px-6 mb-16">
    <h2 class="text-2xl font-bold text-[var(--txt)] mb-6">Principios de Seguridad</h2>
    <div class="grid sm:grid-cols-3 gap-4">
      {securityCards.map((card, i) => (
        <div class="reveal rounded-xl border border-[var(--coral)]/20 bg-white/[0.02] p-5" style={`transition-delay: ${i * 100}ms`}>
          <h3 class="text-sm font-semibold text-[var(--coral)] mb-2">{card.title}</h3>
          <p class="text-xs text-[var(--txt-muted)] leading-relaxed">{card.desc}</p>
        </div>
      ))}
    </div>
  </div>

  <!-- Design principles -->
  <div class="max-w-4xl mx-auto px-4 sm:px-6 pb-20">
    <h2 class="text-2xl font-bold text-[var(--txt)] mb-8">Principios de diseño</h2>
    <div class="grid sm:grid-cols-2 gap-4">
      {principles.map((p) => (
        <div class="rounded-xl border border-white/10 bg-white/[0.02] p-5">
          <h3 class="text-sm font-semibold text-[var(--teal)] mb-2">{p.title}</h3>
          <p class="text-xs text-[var(--txt-muted)] leading-relaxed">{p.desc}</p>
        </div>
      ))}
    </div>
  </div>

<style>
  .reveal { opacity: 0; transform: translateY(20px); transition: opacity 0.5s ease, transform 0.5s ease; }
  .reveal.revealed { opacity: 1; transform: translateY(0); }
  @media (prefers-reduced-motion: reduce) { .reveal { opacity: 1; transform: none; transition: none; } }
  .reveal-lines > * { opacity: 0; transition: opacity 0.4s ease; }
  .reveal-lines.revealed > * { opacity: 1; }
  .reveal-lines.revealed > *:nth-child(1) { transition-delay: 0ms; }
  .reveal-lines.revealed > *:nth-child(2) { transition-delay: 150ms; }
  .reveal-lines.revealed > *:nth-child(3) { transition-delay: 300ms; }
  .reveal-lines.revealed > *:nth-child(4) { transition-delay: 450ms; }
  .reveal-lines.revealed > *:nth-child(5) { transition-delay: 600ms; }
  .reveal-lines.revealed > *:nth-child(6) { transition-delay: 750ms; }
  @media (prefers-reduced-motion: reduce) { .reveal-lines > * { opacity: 1; } }
</style>

<script is:inline>
(function () {
  if (window.matchMedia('(prefers-reduced-motion: reduce)').matches) return;
  var els = document.querySelectorAll('.reveal, .reveal-lines');
  var io = new IntersectionObserver(function (e) {
    e.forEach(function (entry) {
      if (entry.isIntersecting) { entry.target.classList.add('revealed'); io.unobserve(entry.target); }
    });
  }, { threshold: 0.1 });
  els.forEach(function (el) { io.observe(el); });
})();
</script>
</Base>
