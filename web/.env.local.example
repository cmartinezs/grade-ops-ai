# ---------------------------------------------------------------------------
# web/.env.local.example — Variables para desarrollo standalone de web/
# ---------------------------------------------------------------------------
# Copia este archivo a .env.local y completa los valores reales.
# .env.local está en .gitignore y nunca debe commitearse.
#
# Modo global (docker compose): usa el root .env.example en lugar de este.
# Las variables Firebase se baken en el build via Dockerfile ARG/ENV.
# ---------------------------------------------------------------------------

# ---------------------------------------------------------------------------
# Firebase web configuration (PUBLIC — seguro en env.local.example)
# ---------------------------------------------------------------------------
# Valores en: Firebase Console → Project Settings → Your apps
# El prefijo NEXT_PUBLIC_ es obligatorio para exponer al browser bundle.
# NO uses este prefijo para secretos del servidor.

NEXT_PUBLIC_FIREBASE_API_KEY=your-firebase-api-key
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=your-project-id.firebaseapp.com
NEXT_PUBLIC_FIREBASE_PROJECT_ID=your-project-id
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=your-project-id.firebasestorage.app
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=000000000000
NEXT_PUBLIC_FIREBASE_APP_ID=1:000000000000:web:0000000000000000000000
NEXT_PUBLIC_FIREBASE_MEASUREMENT_ID=G-XXXXXXXXXX

# ---------------------------------------------------------------------------
# API backend URL (server-side only — sin prefijo NEXT_PUBLIC_)
# ---------------------------------------------------------------------------
# next.config.ts usa API_BASE_URL para el rewrite proxy /api/* → API.
# En standalone no es necesario: el default es http://localhost:8080.
# Descomenta solo si el API corre en otro puerto o host.
# API_BASE_URL=http://localhost:8080
