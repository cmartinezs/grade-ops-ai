# ---------------------------------------------------------------------------
# .env.local.example — Local development environment variables
# ---------------------------------------------------------------------------
# Copy this file to .env.local and fill in real values for local development.
# .env.local is gitignored and must never be committed to the repository.
#
# In the demo Cloud Run environment these variables are injected automatically
# via Terraform outputs — see infra/terraform/environments/demo/outputs.tf.
# ---------------------------------------------------------------------------

# ---------------------------------------------------------------------------
# Firebase web configuration (PUBLIC — safe to commit to env.local.example)
# ---------------------------------------------------------------------------
# These values come from your Firebase project console or from the Terraform
# outputs of the demo environment:
#   terraform -chdir=infra/terraform/environments/demo output NEXT_PUBLIC_FIREBASE_API_KEY
#
# The NEXT_PUBLIC_ prefix is required so Next.js exposes these variables to
# the browser bundle. Do NOT use this prefix for server-side-only secrets.

NEXT_PUBLIC_FIREBASE_API_KEY=your-firebase-api-key
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=your-project-id.firebaseapp.com
NEXT_PUBLIC_FIREBASE_PROJECT_ID=your-project-id
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=your-project-id.firebasestorage.app
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=000000000000
NEXT_PUBLIC_FIREBASE_APP_ID=1:000000000000:web:0000000000000000000000
NEXT_PUBLIC_FIREBASE_MEASUREMENT_ID=G-XXXXXXXXXX

# ---------------------------------------------------------------------------
# API backend URL
# ---------------------------------------------------------------------------
# For local development the api/ Spring Boot service runs on port 8080.
NEXT_PUBLIC_API_BASE_URL=http://localhost:8080

# ---------------------------------------------------------------------------
# Do NOT add server-side secrets here with the NEXT_PUBLIC_ prefix.
# The Gemini API key and Firebase Admin credentials are server-side only and
# must never reach the browser bundle.
# ---------------------------------------------------------------------------
